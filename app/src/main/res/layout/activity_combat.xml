<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/bg_dark">

    <!-- Threat info card -->
    <TextView
        android:id="@+id/tvThreatInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Threat info"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@color/threat_red"
        android:padding="12dp"
        android:elevation="4dp"
        android:fontFamily="monospace"
        android:layout_marginBottom="8dp"/>

    <!-- Dual Selection Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.8"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Crew A Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="4dp">

            <TextView
                android:id="@+id/tvCrewAName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crew A"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvActionsA"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </LinearLayout>

        <!-- Crew B Section -->
        <LinearLayout
            android:id="@+id/layoutCrewB"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="4dp">

            <TextView
                android:id="@+id/tvCrewBName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crew B"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvActionsB"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Resolve button -->
    <Button
        android:id="@+id/btnResolve"
        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="RESOLVE ROUND"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:backgroundTint="@color/text_primary"
        android:fontFamily="monospace"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Combat log -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tvCombatLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="12sp"
            android:textColor="@color/text_primary"
            android:fontFamily="monospace"
            android:background="@color/bg_dark"
            android:padding="8dp"
            android:lineSpacingExtra="2dp"/>
    </ScrollView>

</LinearLayout>
